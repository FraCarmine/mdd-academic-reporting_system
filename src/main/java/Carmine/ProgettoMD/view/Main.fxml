<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="700.0" prefWidth="950.0"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="Carmine.ProgettoMD.Controller.MainController">

   <VBox AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0"
         AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">

      <!-- ===== HEADER ===== -->
      <HBox alignment="CENTER_LEFT" spacing="15.0"
            style="-fx-background-color: #2c3e50; -fx-padding: 12 20 12 20;">
         <Label text="Gestione Attività" textFill="WHITE">
            <font><Font name="System Bold" size="20.0" /></font>
         </Label>
         <Region HBox.hgrow="ALWAYS" />
         <Label fx:id="lblRuolo" text="Ruolo: -" textFill="#bdc3c7">
            <font><Font size="12.0" /></font>
         </Label>
         <Label fx:id="lblUtente" text="-" textFill="WHITE">
            <font><Font name="System Bold" size="12.0" /></font>
         </Label>
         <Button text="Cambia Ruolo" onAction="#handleCambiaRuolo"
                 style="-fx-background-color: #34495e; -fx-text-fill: white; -fx-cursor: hand;" />
         <Button text="Logout" onAction="#handleLogout"
                 style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-cursor: hand;" />
      </HBox>

      <!-- ===== BARRA AZIONI ===== -->
      <HBox spacing="8.0" style="-fx-background-color: #ecf0f1; -fx-padding: 10 20 10 20;">
         <Button fx:id="btnNuova" text="+ Nuova Attività" onAction="#handleNewAtt" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-cursor: hand; -fx-font-weight: bold;" />
         <Button text="Attività" onAction="#handleMenuAttivita" style="-fx-cursor: hand;" />
         <Button text="Notifiche" onAction="#handleMenuNotifiche" style="-fx-cursor: hand;" />
         <Button text="Report" onAction="#handleMenuReport" style="-fx-cursor: hand;" />
         <Button fx:id="btnAmministrazione" text="Amministrazione" onAction="#handleMenuAmministrazione" style="-fx-cursor: hand;" visible="false" managed="false" />
         
         <Region HBox.hgrow="ALWAYS" />
         <Button text="Dettaglio" onAction="#handleclickDettagli" style="-fx-cursor: hand;" />
		 <Button fx:id="btnModifica" text="Modifica" onAction="#handleModifica" style="-fx-background-color: #2980b9; -fx-text-fill: white; -fx-cursor: hand;" visible="false" managed="false"/>
      </HBox>

      <Separator />

      <!-- ===== FILTRI ===== -->
      <VBox spacing="8.0" style="-fx-padding: 10 20 10 20; -fx-background-color: #f8f9fa;">
         <Label text="Filtri di ricerca" style="-fx-font-weight: bold; -fx-font-size: 13px;" />
         <GridPane hgap="12.0" vgap="8.0">
            <columnConstraints>
               <ColumnConstraints hgrow="SOMETIMES" prefWidth="200.0" />
               <ColumnConstraints hgrow="SOMETIMES" prefWidth="130.0" />
               <ColumnConstraints hgrow="SOMETIMES" prefWidth="150.0" />
               <ColumnConstraints hgrow="SOMETIMES" prefWidth="180.0" />
               <ColumnConstraints hgrow="NEVER" prefWidth="90.0" />
            </columnConstraints>
            <rowConstraints>
               <RowConstraints prefHeight="30.0" />
            </rowConstraints>
            <children>
               <TextField fx:id="txtRicercaTitolo" promptText="Cerca per titolo..."
                          GridPane.columnIndex="0" />
               <ComboBox fx:id="cmbAnno" promptText="Anno..." prefWidth="130.0"
                         GridPane.columnIndex="1" />
               <ComboBox fx:id="cmbStato" promptText="Stato..." prefWidth="150.0"
                         GridPane.columnIndex="2" />
               <ComboBox fx:id="cmbTipo" promptText="Tipo attività..." prefWidth="180.0"
                         GridPane.columnIndex="3" />
               <Button text="Cerca" onAction="#hadleRicercaAtt"
                       style="-fx-background-color: #2980b9; -fx-text-fill: white; -fx-cursor: hand;"
                       prefWidth="90.0" GridPane.columnIndex="4" />
            </children>
         </GridPane>
      </VBox>

      <Separator />

      <!-- ===== TABELLA ===== -->
      <VBox VBox.vgrow="ALWAYS" style="-fx-padding: 10 20 10 20;">
         <HBox alignment="CENTER_LEFT" spacing="10.0" style="-fx-padding: 0 0 8 0;">
            <Label text="Lista Attività" style="-fx-font-weight: bold; -fx-font-size: 14px;" />
            <Label fx:id="lblContatore" text="(0 risultati)"
                   style="-fx-text-fill: #888888; -fx-font-size: 12px;" />
         </HBox>

         <TableView fx:id="tableAttivita" VBox.vgrow="ALWAYS">
            <columns>
               <TableColumn fx:id="colTitolo" text="Titolo" prefWidth="220.0" />
               <TableColumn fx:id="colTipo" text="Tipo" prefWidth="160.0" />
               <TableColumn fx:id="colStato" text="Stato" prefWidth="110.0" />
               <TableColumn fx:id="colDataInizio" text="Data Inizio" prefWidth="100.0" />
               <TableColumn fx:id="colDataFine" text="Data Fine" prefWidth="100.0" />
               <TableColumn fx:id="colPromotore" text="Promotore" prefWidth="150.0" />
            </columns>
            <placeholder>
               <Label text="Nessuna attività trovata." style="-fx-text-fill: #888888;" />
            </placeholder>
         </TableView>
      </VBox>

      <!-- ===== FOOTER ===== -->
      <HBox alignment="CENTER_RIGHT" spacing="10.0"
            style="-fx-background-color: #ecf0f1; -fx-padding: 8 20 8 20;">
         <Label fx:id="lblStatus" text="" style="-fx-font-size: 11px;" />
      </HBox>

   </VBox>
</AnchorPane>
